{:paths ["src"]
 ;; langgraph brings langchain transitively (both zero-/single-dep,
 ;; all .cljc -> portable to JVM / SCI / ClojureScript / GraalVM). It lives
 ;; in the kotoba-lang org of this workspace.
 ;; This vertical wraps THREE bespoke domain capability libraries with the
 ;; governed-actor layer rather than reimplementing their logic:
 ;;   kotoba-lang/logistics -- tracking-number structural contract
 ;;   kotoba-lang/omise     -- store opening-hours/pickup-availability
 ;;   kotoba-lang/okaimono  -- order lifecycle/dispatchability
 ;; This repo is standalone (forkable outside the workspace); the
 ;; :local/root paths only resolve inside the monorepo checkout -- a
 ;; standalone fork should override them with git coordinates.
 :deps {io.github.kotoba-lang/langgraph
        {:local/root "../../kotoba-lang/langgraph"}
        io.github.kotoba-lang/logistics
        {:local/root "../../kotoba-lang/logistics"}
        io.github.kotoba-lang/omise
        {:local/root "../../kotoba-lang/omise"}
        io.github.kotoba-lang/okaimono
        {:local/root "../../kotoba-lang/okaimono"}}
 :aliases
 {;; offline workspace dev -- pin transitive langchain to local checkout
  :dev {:override-deps
        {io.github.kotoba-lang/langchain
         {:local/root "../../kotoba-lang/langchain"}}}
  ;; clojure -M:dev:run  -> drive the demo through one OperationActor
  :run {:main-opts ["-m" "courierops.sim"]}
  ;; clojure -M:dev:render-html [out-file] -> regenerate docs/samples/operator-console.html
  ;; through the real actor (flagship checklist item 2, ADR-2607189300 Wave5).
  :render-html {:main-opts ["-m" "courierops.render-html"]}
  :test {:extra-paths ["test"]
         :extra-deps {io.github.cognitect-labs/test-runner
                      {:git/tag "v0.5.1" :git/sha "dfb30dd"}}
         :main-opts ["-m" "cognitect.test-runner"]
         :exec-fn cognitect.test-runner.api/test}
  ;; static analysis -- clj-kondo from deps (no binary), errors fail CI.
  :lint {:replace-deps {clj-kondo/clj-kondo {:mvn/version "2024.11.14"}}
         :main-opts    ["-m" "clj-kondo.main"
                        "--lint" "src" "test"
                        "--fail-level" "error"]}}}
